    {
      "parameters": {
        "jsCode": "for (let item of $input.all()) {\n  // 1. Get raw HTML generated by the Browserless node\n  let rawHtml = item.json.data?.[0]?.results?.[0]?.html || \"\";\n  \n  // 2. Clean HTML to keep only useful text for AI\n  // Remove scripts and CSS\n  let cleanText = rawHtml.replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, ' ');\n  cleanText = cleanText.replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, ' ');\n  \n  // Remove all other HTML tags\n  cleanText = cleanText.replace(/<[^>]+>/g, ' ');\n  \n  // Clean extra spaces\n  cleanText = cleanText.replace(/\\s+/g, ' ').trim();\n  \n  // 3. Create the variable that Gemini expects\n  item.json.clean_text = cleanText;\n}\n\nreturn $input.all();"
      },
